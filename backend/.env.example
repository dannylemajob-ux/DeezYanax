# ── Telegram MTProto (obligatorio) ───────────────────────────────────────────
# Obtén estos datos en: https://my.telegram.org/apps
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# Número de teléfono de tu cuenta Telegram (con código de país)
TELEGRAM_PHONE=+591XXXXXXXXX

# Nombre del archivo de sesión (se crea automáticamente al primer login)
TELEGRAM_SESSION=deezyanax_session

# ── Servidor ──────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0

# ── Login web (obligatorio en producción) ────────────────────────────────────
DEEZYANAX_AUTH_USER=yanax
DEEZYANAX_AUTH_PASSWORD=change-me
DEEZYANAX_AUTH_SECRET=generate-a-long-random-secret
